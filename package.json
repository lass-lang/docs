{
  "name": "@lass-lang/docs",
  "version": "0.0.1",
  "type": "module",
  "description": "Lass language documentation with tested code examples",
  "exports": {
    ".": {
      "types": "./src/extractor.ts",
      "import": "./src/extractor.ts"
    },
    "./test-helpers": {
      "types": "./src/test-helpers.ts",
      "import": "./src/test-helpers.ts"
    }
  },
  "scripts": {
    "lint:docs": "tsx scripts/lint-docs.ts",
