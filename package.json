    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@lass-lang/core": "workspace:*",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "tsx": "^4.19.4",
    "vitest": "^4.0.18"
  }
}
